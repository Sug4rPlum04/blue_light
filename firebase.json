{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "flutter": {
    "platforms": {
      "android": {
        "default": {
          "projectId": "replace-with-your-firebase-project-id",
          "appId": "replace-with-your-android-app-id",
          "fileOutput": "android/app/google-services.json"
        }
      },
      "dart": {
        "lib/firebase_options.dart": {
          "projectId": "replace-with-your-firebase-project-id",
          "configurations": {
            "android": "replace-with-android-app-id",
            "ios": "replace-with-ios-app-id",
            "macos": "replace-with-macos-app-id",
            "web": "replace-with-web-app-id",
            "windows": "replace-with-windows-app-id"
          }
        }
      }
    }
  }
}
